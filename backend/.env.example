# ─── Vision ───────────────────────────────────────
# Choose your vision provider: "claude" or "gemini"
VISION_PROVIDER=claude

# Anthropic (required if VISION_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...

# Google (required if VISION_PROVIDER=gemini)
GOOGLE_API_KEY=...

# ─── TTS ──────────────────────────────────────────
ELEVENLABS_API_KEY=...

# ─── Pricing ─────────────────────────────────────
# eBay (always required — default/fallback pricing source)
EBAY_CLIENT_ID=YourApp-...
EBAY_CLIENT_SECRET=...

# Discogs (required for vinyl/music pricing)
DISCOGS_TOKEN=...

# Pokémon TCG API (optional — raises rate limit)
POKEMON_TCG_API_KEY=...

# ─── Supabase ────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Anon key is used by the iOS app only, not the backend
# SUPABASE_ANON_KEY=eyJ...

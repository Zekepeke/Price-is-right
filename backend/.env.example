# ─── Vision ───────────────────────────────────────
# Choose your vision provider: "claude" or "gemini"
VISION_PROVIDER=claude

# Anthropic (required if VISION_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...

# Google (required if VISION_PROVIDER=gemini OR TTS_PROVIDER=gemini)
GOOGLE_API_KEY=...

# ─── TTS ──────────────────────────────────────────
# Choose your TTS provider: "gemini" or "elevenlabs"
TTS_PROVIDER=gemini

# ElevenLabs (required if TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=...

# ─── Pricing ─────────────────────────────────────
# eBay (always required — default pricing source)
EBAY_CLIENT_ID=YourApp-...
EBAY_CLIENT_SECRET=...

# Discogs (required for vinyl/music pricing)
DISCOGS_TOKEN=...

# JustTCG (required for trading card pricing)
JUSTTCG_API_KEY=...

# ─── Supabase ────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Anon key is used by the iOS app only, not the backend
# SUPABASE_ANON_KEY=eyJ...

# Discogs Api Key
DISCOGS_TOKEN=...